{
  "name": "scootlens-console",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "ScootLens Web Console (P2: Dashboard / Approvals / Journal)",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
